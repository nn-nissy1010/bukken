# deploy/.env.example — コピーして deploy/.env を作り、実値を入れる。
# .env は Git に載せない（.gitignore 済み）。認証情報を含むため取り扱い注意。

# --- SSH（テーマ転送・WP-CLI実行に使用。お名前.com のSSH情報） ---
SSH_HOST=your-server.example.com
SSH_USER=your-ssh-user
SSH_PORT=22
# サーバー上の WordPress ルート（wp-config.php がある場所）
REMOTE_WP_PATH=/home/your-user/public_html

# --- 本番サイト ---
SITE_URL=https://example.com          # メインサイト（雛形）のURL
NETWORK_TITLE=居住者専用サイト
ADMIN_USER=mrc-admin
ADMIN_EMAIL=admin@example.com

# --- WP-CLI（サーバーにwpコマンドが無い場合のフォールバック） ---
# 例：WP_CLI="php ~/wp-cli.phar"  （SSHでphar配置した場合）
WP_CLI=wp
